@using PWA.Constants

<div class="container-fluid px-0">
	<div class="d-flex align-items-center justify-content-between bg-primary text-white p-2 navbar navbar-dark">
		<div class="d-flex align-items-center gap-2">
			<HomeImgButton />
			<ConnectionStatus />
		</div>
		<Title />
		<div class="d-flex align-items-center gap-2">
			<ThemeToggle />
			<MenuOffCanvasToggle />
		</div>
	</div>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="@DomIds.Menu.OffCanvas"
		 aria-labelledby="@DomIds.Menu.OffCanvasLabel" style="width: 260px;">

	<div class="offcanvas-header">
		<h5 class="offcanvas-title" id="@DomIds.Menu.OffCanvasLabel">Menu</h5>
		<button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
	</div>

	<div class="offcanvas-body px-0">
		<nav class="nav flex-column">
			@foreach (var item in Enums.Nav.List.ToList()
			@* .Where(w => w != Nav.Test).Where(w => w != Nav.ShareTarget) *@
			.OrderBy(o => o.Name))
			{
				<a class="nav-link px-3" href="@item.Index"><i class="@item.Icon"></i> @item.Title</a>
				@*  @item.IconColor *@
			}
		</nav>
	</div>

	<img src="/images/jkm-branding-iron-shorter.jpg" class="img-fluid rounded-start m-2" alt="JKM Branding Iron Logo">

</div>


