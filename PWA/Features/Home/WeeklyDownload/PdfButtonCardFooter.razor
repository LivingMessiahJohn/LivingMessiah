@inject IBlobApiService BlobApiService
@inject ILogger<PdfButtonCardFooter>? Logger

<div class="card-footer">

	@if (HasConnectionStatus)
	{
		<div class="text-center">
			<LoadingComponentLIBRARY IsLoading="CurrentReadingFilenameRecord == null" TurnSpinnerOff=TurnSpinnerOff>
				<PdfButton CurrentReadingFilenameRecord="CurrentReadingFilenameRecord" />
			</LoadingComponentLIBRARY>
		</div>
	}
	else
	{
		<RCL.Components.Alert><code>HasConnectionStatus IS FALSE</code>: Can't validate PDF! Not Connected!</RCL.Components.Alert>
	}
</div>


@code {
	[Parameter, EditorRequired] public bool HasConnectionStatus { get; set; }
	[Parameter, EditorRequired] public string WeeklyReadingParashaFile { get; set; }

	protected CurrentReadingFilenameRecord? CurrentReadingFilenameRecord;

	bool TurnSpinnerOff = false;
	protected override async Task OnInitializedAsync()
	{
		//Logger!.LogDebug("{Method}, {Message}", $"{nameof(PdfButtonCardFooter)}!{nameof(OnInitializedAsync)}", "Start");
		try
		{
			await Task.Delay(500);
			var blobInfoResponse = await BlobApiService.GetBlobInfoAsync(WeeklyReadingParashaFile);

			if (blobInfoResponse.IsTransient)
			{
				Logger!.LogWarning("Transient error getting blob info: {Message}", blobInfoResponse.Message);
				CurrentReadingFilenameRecord = new CurrentReadingFilenameRecord(WeeklyReadingParashaFile, string.Empty, 0);
				return;
			}

			if (blobInfoResponse.Exists && blobInfoResponse.BlobInfo is not null)
			{
				CurrentReadingFilenameRecord = new CurrentReadingFilenameRecord(
					blobInfoResponse.BlobInfo.Name,
					blobInfoResponse.BlobInfo.Url,
					blobInfoResponse.BlobInfo.SizeBytes);

				Logger!.LogInformation("Blob info retrieved: {Name}, Size: {Size} bytes", 
					blobInfoResponse.BlobInfo.Name, blobInfoResponse.BlobInfo.SizeBytes);
			}
			else
			{
				Logger!.LogWarning("Blob not found or info unavailable: {Message}", blobInfoResponse.Message);
				CurrentReadingFilenameRecord = new CurrentReadingFilenameRecord(WeeklyReadingParashaFile, string.Empty, 0);
			}
		}
		catch (Exception ex)
		{
			Logger!.LogError(ex, "{Method} {Message}", nameof(OnInitializedAsync), $"WeeklyReadingParashaFile: {WeeklyReadingParashaFile}");
			CurrentReadingFilenameRecord = new CurrentReadingFilenameRecord(WeeklyReadingParashaFile, string.Empty, 0);
		}
		finally
		{
			TurnSpinnerOff = true;
		}
	}

}
