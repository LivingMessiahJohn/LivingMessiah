@using PWA.Features.Welcome
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

@* @inject ILogger<WelcomeCard>? Logger *@

<div class="card bg-warning-subtle">
	<div class="card-header">
		<div class="d-flex justify-content-between">
			<span class="text-dark">
				<i class="@Nav.Welcome.Icon fa-fw fa-3x"></i>
			</span>
			<h1 class="@Nav.Welcome.TextColor text-center pt-1"><b>Welcome</b></h1>
			<ShowHideToggle ContentIsShowing="ShowingDetails"
											OnToggleSelected="ReturnedToggle" />
		</div>

		@if (ShowingDetails)
		{
			<hr />
			
			<TableOfContent BaseUrl="/#" />
			<Introduction />
			<Vision />
			<Mission />
			<Resolve />

			<div class="card-footer float-end">
				<ShowHideToggle ContentIsShowing="ShowingDetails"
												OnToggleSelected="ReturnedToggle" />
			</div>
		}
	</div>
</div>

@code {

	private IJSObjectReference? _module;
	bool ShowingDetails;

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			_module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./Features/Home/WelcomeCard.razor.js");
			ShowingDetails = await _module.InvokeAsync<bool>("getShowingDetails");
			StateHasChanged();
		}
	}

	private async Task ReturnedToggle()
	{
		ShowingDetails = !ShowingDetails;
		if (_module is not null)
		{
			await _module.InvokeVoidAsync("setShowingDetails", ShowingDetails);
		}
	}

	async ValueTask IAsyncDisposable.DisposeAsync()
	{
		if (_module is not null)
		{
			await _module.DisposeAsync();
		}
	}
}
