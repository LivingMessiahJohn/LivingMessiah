@using PWA.Helpers
@using System.Linq

<div class="btn-group-vertical btn-group-md dropstart"
		 role="group" aria-label="Vertical button group">

	<button type="button" class="btn btn-primary dropdown-toggle"
					data-bs-toggle="dropdown" aria-expanded="false">
		<i class="fas fa-cogs"></i>
	</button>

	<ul class="dropdown-menu">

		@foreach (var group in Enums.ModalMenuItem.List
							.GroupBy(item => item.Category)
							.OrderBy(g => g.Key))
		{
			<li><strong class="dropdown-header">@group.Key</strong></li>

			@foreach (var item in group.OrderBy(o => o.Value))
			{
				<li class="dropdown-item">
					<button @onclick="@(e => ButtonClick(item))"
									type="button" class="btn btn-outline-primary btn-sm">
						@item.Title
					</button>
				</li>
			}
			<li><hr class="dropdown-divider" /></li>
		}

		<li><strong class="dropdown-header">Print Friendly</strong></li>
		<li class="dropdown-item">
			<button @onclick="ButtonClickPrintFriendly" class="btn btn-outline-secondary" title="Print Friendly View">
				<i class="fa fa-print"></i>
			</button>
		</li>

	</ul>

</div>

@code {
	[Parameter, EditorRequired] public EventCallback<Enums.ModalMenuItem> OnModalSelected { get; set; }
	[Parameter, EditorRequired] public EventCallback OnPrintFriendlySelected { get; set; }

	private void ButtonClick(Enums.ModalMenuItem language)
	{
		OnModalSelected.InvokeAsync(language);
	}

	private void ButtonClickPrintFriendly()
	{
		OnPrintFriendlySelected.InvokeAsync();
	}

}
