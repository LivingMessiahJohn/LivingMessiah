
<nav class="navbar navbar-expand bg-primary-subtle">

	<div class="collapse navbar-collapse justify-content-between">

		<div class="mx-1">
			@PrevButtonDivRF
		</div>

		<div class="col">
			@if (Section != 0)
			{
				@ProgressBarDivRF
			}
			else
			{
				<div class="col">Sec:@Section	</div>
			}
		
		</div>

		<div class="ms-1">
			@NextButtonDivRF
		</div>

	</div>

	<div class="d-flex justify-content-end me-1">
		@JustifyEndRF
	</div>

</nav>

<br />

@code {
	[Parameter, EditorRequired] public RenderFragment? PrevButtonDivRF { get; set; }
	[Parameter, EditorRequired] public RenderFragment? ProgressBarDivRF { get; set; }
	[Parameter, EditorRequired] public RenderFragment? NextButtonDivRF { get; set; }
	[Parameter, EditorRequired] public RenderFragment? JustifyEndRF { get; set; }
	[Parameter, EditorRequired] public int Section { get; set; }
}
