@inject ILogger<Details>? Logger

<div class="row">
	@foreach (var item in Enums.Links.List.ToList())
	{
		var componentType = GetComponentType(item.Name);
		if (componentType is not null)
		{
			<div class="col-12 col-md-6 col-lg-4 my-1">
				<DynamicComponent Type="componentType" />
			</div>
		}
	}
</div>

@code {
	protected Type? GetComponentType(string name)
	{
		try
		{
			return Type.GetType($"{Constants.DynamicComponentPath}.{name}");
		}
		catch (Exception ex)
		{
			Logger?.LogError(ex, "Failed to get component type for {Name}", name);
			return null;
		}
	}

}
